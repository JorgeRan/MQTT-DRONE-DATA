{
  "name": "mqtt-drone-data-electron",
  "version": "1.0.1",
  "private": true,
  "author": "JorgeRan",
  "description": "Electron desktop app for drone telemetry and methane visualization",
  "main": "electron/main.cjs",
  "scripts": {
    "dev:web": "npm --prefix app run dev",
    "dev:electron": "wait-on tcp:5173 && cross-env ELECTRON_START_URL=http://localhost:5173 electron .",
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "start": "npm run build:web && electron .",
    "build:web": "npm --prefix app run build",
    "build": "npm run build:web && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "dist": "npm run build",
    "lint": "npm --prefix app run lint",
    "publish": "npm run build:web && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --publish always"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "events": "^3.3.0",
    "express": "^5.2.1",
    "http": "^0.0.1-security",
    "mqtt": "^5.15.0",
    "n-gram": "^2.0.2",
    "path": "^0.12.7",
    "postgres": "^3.4.8",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "ws": "^8.18.3",
    "url": "^0.11.4"
  },
  "devDependencies": {
    "@electron-forge/publisher-github": "^7.11.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^37.2.4",
    "electron-builder": "^26.0.12",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.jorgeran.mqttdronedata",
    "productName": "MQTT Drone Data",
    "directories": {
      "app": ".",
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "build/icon.png",
      "electron/**/*",
      "app/dist/**/*",
      "backend/**/*",
      "mqtt-bridge/**/*",
      "package.json"
    ],
    "publish": {
      "provider": "github",
      "owner": "JorgeRan",
      "repo": "EERL-Drone-Dashboard"
    },
    "extraResources": [
      {
        "from": "mqtt-bridge",
        "to": "mqtt-bridge",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": false,
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage"
      ]
    }
  }
}
